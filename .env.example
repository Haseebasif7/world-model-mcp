# ── verify-action-mcp configuration ──────────────────────────────────────────
#
# Choose ONE backend by setting WORLD_MODEL_BACKEND, then fill in the
# corresponding key/URL below. Copy this file to .env and edit it:
#     cp .env.example .env
#
# Options (pick what you have — you do NOT need a GPU to start):
#   groq            → Free, no credit card. Hosted.  Key: https://console.groq.com
#   together        → $25 free credit.      Hosted.  Key: https://api.together.ai
#   qwen_agentworld → The real world model, self-hosted. Run it LOCALLY with a
#                     quantized GGUF (Ollama/llama.cpp) or in the CLOUD on a
#                     rented GPU (vLLM/SGLang). See README "Running the real model".

WORLD_MODEL_BACKEND=groq

# ── Groq (default — easiest, free, no GPU) ────────────────────────────────────
GROQ_API_KEY=

# ── Together AI ───────────────────────────────────────────────────────────────
# NOTE: confirm the exact model id against your Together dashboard — serverless
# catalogs change and a wrong id returns "model not found".
TOGETHER_API_KEY=

# ── Qwen-AgentWorld (self-hosted: local OR cloud) ─────────────────────────────
# Point this at any OpenAI-compatible endpoint serving the model. No API key
# needed. Common choices:
#   Ollama (local):                QWEN_AGENTWORLD_URL=http://localhost:11434
#   llama.cpp / LM Studio (local): QWEN_AGENTWORLD_URL=http://localhost:8080
#   vLLM / SGLang (cloud GPU):      QWEN_AGENTWORLD_URL=http://YOUR_HOST:8000
QWEN_AGENTWORLD_URL=http://localhost:11434
#
# The served model NAME differs by runtime. Set this to match your server:
#   Ollama:        QWEN_AGENTWORLD_MODEL=hf.co/unsloth/Qwen-AgentWorld-35B-A3B-GGUF:Q4_K_M
#   vLLM/SGLang:   QWEN_AGENTWORLD_MODEL=Qwen/Qwen-AgentWorld-35B-A3B  (the default)
QWEN_AGENTWORLD_MODEL=Qwen/Qwen-AgentWorld-35B-A3B
